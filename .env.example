# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
GITHUB_REPO=your_blog_repository_name
GITHUB_EMAIL=your_email@example.com
GITHUB_BRANCH=main  # or gh-pages depending on your setup

# Blog Settings
BLOG_POST_PATH=_posts
BLOG_IMAGE_PATH=assets/images
POSTS_PER_DAY=3  # Number of posts to generate daily
MAX_WORDS_PER_POST=1000  # Maximum number of words per post

# AI Provider Settings
AI_PROVIDER=openai  # options: openai, gemini
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo  # or gpt-4
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro

# RSS Feed Configuration
# Comma-separated list of RSS feed URLs
RSS_FEEDS=https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml,https://www.wired.com/feed/rss,https://feeds.arstechnica.com/arstechnica/index
MAX_RSS_ITEMS=25  # Maximum number of RSS items to fetch per feed
MAX_ARTICLE_AGE_DAYS=3  # Only consider articles published within this many days

# Jekyll Settings
JEKYLL_CATEGORIES=Technology,News,AI,Programming
JEKYLL_TAGS=tech,news,programming,artificial-intelligence,development
AUTHOR_NAME="Rajan Sandha"
SITE_URL=https://rajan-sandha.github.io

# Ad Configuration
ADS_ENABLED=false
# Position options: sidebar, content_top, content_bottom, after_paragraph
ADS_POSITION=sidebar

# Google AdSense Configuration
ADS_GOOGLE_PUBLISHER_ID=your-publisher-id
ADS_GOOGLE_AD_SLOT=your-ad-slot
ADS_GOOGLE_FORMAT=auto

# Amazon Associates Configuration
ADS_AMAZON_TRACKING_ID=your-amazon-tracking-id
ADS_AMAZON_MARKETPLACE=US
ADS_AMAZON_AD_TYPE=banner

# Custom Ad HTML
ADS_CUSTOM_HTML=<div class="custom-ad">Your custom ad code here</div>

# SEO Configuration 
SEO_ENABLE_OPENGRAPH=true
SEO_ENABLE_TWITTER_CARDS=true
SEO_ENABLE_SCHEMA_ORG=true
SEO_ENABLE_SITEMAP=true
SEO_ENABLE_ROBOTS_TXT=true
SEO_TWITTER_USERNAME=your_twitter_username
